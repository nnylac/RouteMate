{
  "name": "RouteMate",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/main",
    "start:card-orchestrator-service": "nest start card-orchestrator-service --watch",
    "start:card-service": "nest start card-service --watch",
    "start:fare-comparison-service": "nest start fare-comparison-service --watch",
    "start:fare-service": "nest start fare-service --watch",
    "start:maps-wrapper-service": "nest start maps-wrapper-service --watch",
    "start:notification-service": "nest start notification-service --watch",
    "start:payment-wrapper-service": "nest start payment-wrapper-service --watch",
    "start:transaction-service": "nest start transaction-service --watch",
    "start:ride-hailing-aggregator-service": "nest start ride-hailing-aggregator-service --watch",
    "start:ride-hailing-wrapper-service": "nest start ride-hailing-wrapper-service --watch",
    "start:route-cache-service": "nest start route-cache-service --watch",
    "start:user-service": "nest start user-service --watch",
    "start:arrival-timing-service": "nest start arrival-timing-service --watch",
    "start:route-planner-orchestrator-service": "nest start route-planner-orchestrator-service --watch",
    "start:all": "concurrently \"npm run start\" \"npm run start:card-orchestrator-service\" \"npm run start:card-service\" \"npm run start:fare-comparison-service\" \"npm run start:fare-service\" \"npm run start:maps-wrapper-service\" \"npm run start:notification-service\" \"npm run start:payment-wrapper-service\" \"npm run start:transaction-service\" \"npm run start:ride-hailing-aggregator-service\" \"npm run start:ride-hailing-wrapper-service\" \"npm run start:route-cache-service\" \"npm run start:user-service\" \"npm run start:arrival-timing-service\" \"npm run start:route-planner-orchestrator-service\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api-gateway/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parser": "^3.2.0",
    "jslint": "^0.12.1",
    "mongoose": "^9.3.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
