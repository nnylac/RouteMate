{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api-gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/api-gateway",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "arrival-timing-service": {
      "type": "application",
      "root": "apps/arrival-timing-service",
      "entryFile": "main",
      "sourceRoot": "apps/arrival-timing-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/arrival-timing-service/tsconfig.app.json"
      }
    },
    "card-orchestrator-service": {
      "type": "application",
      "root": "apps/card-orchestrator-service",
      "entryFile": "main",
      "sourceRoot": "apps/card-orchestrator-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/card-orchestrator-service/tsconfig.app.json"
      }
    },
    "card-service": {
      "type": "application",
      "root": "apps/card-service",
      "entryFile": "main",
      "sourceRoot": "apps/card-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/card-service/tsconfig.app.json"
      }
    },
    "fare-comparison-service": {
      "type": "application",
      "root": "apps/fare-comparison-service",
      "entryFile": "main",
      "sourceRoot": "apps/fare-comparison-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/fare-comparison-service/tsconfig.app.json"
      }
    },
    "fare-service": {
      "type": "application",
      "root": "apps/fare-service",
      "entryFile": "main",
      "sourceRoot": "apps/fare-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/fare-service/tsconfig.app.json",
        "assets": [
          {
            "include": "../data/**/*",
            "outDir": "dist/apps/fare-service/data"
          }
        ],
        "watchAssets": true
      }
    },
    "maps-wrapper-service": {
      "type": "application",
      "root": "apps/maps-wrapper-service",
      "entryFile": "main",
      "sourceRoot": "apps/maps-wrapper-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/maps-wrapper-service/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    },
    "payment-wrapper-service": {
      "type": "application",
      "root": "apps/payment-wrapper-service",
      "entryFile": "main",
      "sourceRoot": "apps/payment-wrapper-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payment-wrapper-service/tsconfig.app.json"
      }
    },
    "ride-hailing-aggregator-service": {
      "type": "application",
      "root": "apps/ride-hailing-aggregator-service",
      "entryFile": "main",
      "sourceRoot": "apps/ride-hailing-aggregator-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ride-hailing-aggregator-service/tsconfig.app.json"
      }
    },
    "ride-hailing-wrapper-service": {
      "type": "application",
      "root": "apps/ride-hailing-wrapper-service",
      "entryFile": "main",
      "sourceRoot": "apps/ride-hailing-wrapper-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ride-hailing-wrapper-service/tsconfig.app.json"
      }
    },
    "route-cache-service": {
      "type": "application",
      "root": "apps/route-cache-service",
      "entryFile": "main",
      "sourceRoot": "apps/route-cache-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/route-cache-service/tsconfig.app.json"
      }
    },
    "route-planner-orchestrator-service": {
      "type": "application",
      "root": "apps/route-planner-orchestrator-service",
      "entryFile": "main",
      "sourceRoot": "apps/route-planner-orchestrator-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/route-planner-orchestrator-service/tsconfig.app.json"
      }
    },
    "transaction-service": {
      "type": "application",
      "root": "apps/transaction-service",
      "entryFile": "main",
      "sourceRoot": "apps/transaction-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/transaction-service/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    }
  }
}