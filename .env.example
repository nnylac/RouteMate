# General
NODE_ENV=development

# Frontend
VITE_API_BASE_URL=http://localhost:3000

# API Gateway
API_GATEWAY_PORT=3000

# Services
CARD_ORCHESTRATOR_SERVICE_PORT=3001
CARD_SERVICE_PORT=3002
FARE_COMPARISON_SERVICE_PORT=3003
FARE_SERVICE_PORT=3004
MAPS_WRAPPER_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
PAYMENT_WRAPPER_SERVICE_PORT=3007
RIDE_HAILING_AGGREGATOR_SERVICE_PORT=3008
RIDE_HAILING_WRAPPER_SERVICE_PORT=3009
ROUTE_CACHE_SERVICE_PORT=3010
TRANSACTION_SERVICE_PORT=3011
USER_SERVICE_PORT=3012
ARRIVAL_TIMING_SERVICE_PORT=3013
ROUTE_PLANNER_ORCHESTRATOR_SERVICE_PORT=3014

# Mongo
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_ROOT_USER=<your_mongo_user>
MONGO_ROOT_PASSWORD=<your_mongo_password>

# Example connection format:
# mongodb://<user>:<password>@localhost:27017/<db>?authSource=admin

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=<your_postgres_user>
POSTGRES_PASSWORD=<your_postgres_password>
POSTGRES_DB=postgres

# Each service should use its own DB
# Examples:
# POSTGRES_DB=user_service_db
# POSTGRES_DB=card_service_db
# POSTGRES_DB=fare_service_db
# POSTGRES_DB=transaction_service_db

# RabbitMQ
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# External APIs
# MAPS_API_KEY=your_maps_key_here
# PAYMENT_API_KEY=your_payment_key_here
# RIDE_HAILING_API_KEY=your_ride_hailing_key_here